INSERT INTO Quizzes (LessonTitle, QuestionText, OptionA, OptionB, OptionC, OptionD, CorrectAnswer, Explanation) VALUES 
('Java Thread.sleep() Method', 'What is the exact behavioral effect of invoking the static ''Thread.sleep(long millis)'' method?', 'It permanently suspends the current thread until ''notify()'' is called.', 'It pauses the execution of the specific thread object it was called on.', 'It causes the currently executing thread to temporarily cease execution and enter the TIMED_WAITING state for the specified duration, without releasing any acquired monitor locks.', 'It sends the thread to the background to execute at a lower priority.', 'C', 'Because ''sleep()'' is a static method, it always acts upon the thread that is currently executing the instruction. It pauses execution for the given milliseconds, but crucially, it does NOT release any intrinsic locks the thread is currently holding within a synchronized block.');

INSERT INTO Quizzes (LessonTitle, QuestionText, OptionA, OptionB, OptionC, OptionD, CorrectAnswer, Explanation) VALUES 
('Java Thread.sleep() Method', 'What mandatory checked exception must be handled or declared when calling ''Thread.sleep()''?', 'TimeoutException', 'InterruptedException', 'IllegalMonitorStateException', 'IllegalThreadStateException', 'B', 'While a thread is sleeping, another thread can invoke ''interrupt()'' on it. Because the sleeping thread is in a blocking state, the JVM immediately wakes it up and throws an ''InterruptedException'', forcing the developer to write a catch block to handle this specific asynchronous disruption.');

INSERT INTO Quizzes (LessonTitle, QuestionText, OptionA, OptionB, OptionC, OptionD, CorrectAnswer, Explanation) VALUES 
('Java Thread.sleep() Method', 'If you execute ''Thread t1 = new Thread(myRunnable); t1.start(); t1.sleep(5000);'' from the main thread, which thread actually goes to sleep?', 'Thread t1 goes to sleep.', 'Both the main thread and t1 go to sleep.', 'The main thread goes to sleep.', 'Neither thread sleeps; a compilation error occurs.', 'C', 'This is a classic trap. Even though you use the reference variable ''t1'' to call ''sleep()'', ''sleep()'' is a static method. The Java compiler resolves static method calls based on the class, not the instance. Therefore, it is translated to ''Thread.sleep(5000)'', putting the currently executing thread (the main thread) to sleep, not ''t1''.');

INSERT INTO Quizzes (LessonTitle, QuestionText, OptionA, OptionB, OptionC, OptionD, CorrectAnswer, Explanation) VALUES 
('Java Thread.sleep() Method', 'What occurs at runtime if you pass a negative integer to ''Thread.sleep()'', such as ''Thread.sleep(-100)''?', 'The thread sleeps forever.', 'The method is ignored, and execution continues immediately.', 'The JVM throws an ''IllegalArgumentException''.', 'The JVM throws a ''NegativeArraySizeException''.', 'C', 'Time cannot be negative. Passing a negative millisecond value violates the method''s contract, and the JVM instantly rejects it by throwing an ''IllegalArgumentException'' specifying that the timeout value is negative.');

INSERT INTO Quizzes (LessonTitle, QuestionText, OptionA, OptionB, OptionC, OptionD, CorrectAnswer, Explanation) VALUES 
('Java Thread.sleep() Method', 'How does the JVM guarantee the exact precision of the ''Thread.sleep(long millis, int nanos)'' method?', 'It uses a dedicated high-frequency CPU core.', 'It guarantees nanosecond precision on all hardware architectures.', 'It provides no absolute guarantee; the precision and accuracy of the sleep period are heavily dependent on the underlying operating system''s timers and thread schedulers.', 'It pauses the system clock.', 'C', 'Java cannot guarantee absolute real-time precision. The ''sleep()'' method relies entirely on the host operating system''s thread scheduling accuracy and timer granularity. In many standard OS environments, requesting a sleep of 1 millisecond might actually result in a sleep of 10-15 milliseconds.');
